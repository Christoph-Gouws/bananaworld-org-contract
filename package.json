{
  "name": "@bananaworld/org-contract",
  "version": "0.3.0",
  "private": true,
  "description": "THE single shared consumption contract for the Bananaworld estate's central org layer (Org Admin EPIC-008-M005, DECISION-GATE-013). One implementation of: identity resolution (API-IDENT-001), master reads + the least-privilege scope matrix (API-MASTER-001), the station-PIN auth flow (verify + keyed pin_lookup + lockout + session open/close + station token), UUID-keyed central-master overlay helpers, the Estate Station Directory read, and the estate audit standard + app-path writer. Replaces the four hand-mirrored copies (org-admin internal, DC, CRM, RMS). Shipped as TypeScript source; consumers transpile it via Next.js transpilePackages. Config is INJECTED (configureOrgContract) — this package never reads process.env.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "files": [
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./standards": {
      "types": "./src/standards.ts",
      "default": "./src/standards.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "default": "./src/config.ts"
    },
    "./queryable": {
      "types": "./src/queryable.ts",
      "default": "./src/queryable.ts"
    },
    "./tx": {
      "types": "./src/db/tx.ts",
      "default": "./src/db/tx.ts"
    },
    "./pin": {
      "types": "./src/auth/pin.ts",
      "default": "./src/auth/pin.ts"
    },
    "./station-pin": {
      "types": "./src/auth/station-pin.ts",
      "default": "./src/auth/station-pin.ts"
    },
    "./station-session": {
      "types": "./src/auth/station-session.ts",
      "default": "./src/auth/station-session.ts"
    },
    "./station-token": {
      "types": "./src/auth/station-token.ts",
      "default": "./src/auth/station-token.ts"
    },
    "./station-pairing": {
      "types": "./src/auth/station-pairing.ts",
      "default": "./src/auth/station-pairing.ts"
    },
    "./station-attribution": {
      "types": "./src/auth/station-attribution.ts",
      "default": "./src/auth/station-attribution.ts"
    },
    "./person-read": {
      "types": "./src/identity/person-read.ts",
      "default": "./src/identity/person-read.ts"
    },
    "./credential-repo": {
      "types": "./src/identity/credential-repo.ts",
      "default": "./src/identity/credential-repo.ts"
    },
    "./registry": {
      "types": "./src/registry/apps.ts",
      "default": "./src/registry/apps.ts"
    },
    "./resolver": {
      "types": "./src/contract/resolver.ts",
      "default": "./src/contract/resolver.ts"
    },
    "./master-read": {
      "types": "./src/contract/master-read.ts",
      "default": "./src/contract/master-read.ts"
    },
    "./overlay": {
      "types": "./src/masters/overlay.ts",
      "default": "./src/masters/overlay.ts"
    },
    "./directory": {
      "types": "./src/stations/directory.ts",
      "default": "./src/stations/directory.ts"
    },
    "./audit-writer": {
      "types": "./src/audit/app-writer.ts",
      "default": "./src/audit/app-writer.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
